# --- Revenue Recall configuration ---
# Everything is optional: with no env vars the app runs on the built-in,
# in-memory CRM seeded with realistic demo data.

# Industry template (see src/lib/industries): real_estate | mortgage | insurance
# | saas | agency | auto | home_services | generic
NEXT_PUBLIC_INDUSTRY=real_estate

# Display name shown in the sidebar.
NEXT_PUBLIC_ORG_NAME="Your Company"

# Monthly revenue goal used for goal/forecast attainment.
NEXT_PUBLIC_MONTHLY_QUOTA=250000

# Active CRM provider: builtin | close | hubspot | salesforce | pipedrive
CRM_PROVIDER=builtin

# Persist the built-in (demo) CRM to disk so edits survive restarts on local /
# self-hosted node deploys. Off by default (pure in-memory, reseeds each boot).
# Production persistence is Supabase, not this. Optional dir override.
BUILTIN_PERSIST=false
# BUILTIN_PERSIST_DIR=.data

# --- AI execution layer (optional) ---
# With no key, AI drafting & briefs fall back to high-quality templates.
# Set this to generate tailored outreach and deal briefs with Claude.
ANTHROPIC_API_KEY=
# Optional: pin a model (defaults to claude-opus-4-8). Use claude-haiku-4-5 for
# faster/cheaper drafting at scale.
ANTHROPIC_MODEL=
# Optional thinking effort floor: low | medium | high | xhigh | max (Opus 4.6+).
# Higher = deeper reasoning but materially more tokens/cost — with a budget cap
# set, "xhigh"/"max" across all short drafts can exhaust it and force the
# template fallback. Leave unset for the per-call default; reserve xhigh/max for
# intelligence-heavy work.
ANTHROPIC_EFFORT=
# Optional margin guard: cap AI spend per org per month (USD). When hit, drafting
# transparently falls back to the free templates. 0 / unset = unlimited.
AI_MONTHLY_BUDGET_USD=
# Per-client burst guard on AI/voice endpoints (requests/min, default 30).
AI_RATE_LIMIT_PER_MIN=
# Per-client burst guard on state-mutating / send endpoints (requests/min, default 120).
WRITE_RATE_LIMIT_PER_MIN=
# Optional price overrides (USD per 1M tokens) if list prices change:
# AI_PRICE_OPUS_IN= / AI_PRICE_OPUS_OUT= / AI_PRICE_SONNET_IN= / ... / AI_PRICE_HAIKU_OUT=

# --- Close CRM (optional) ---
# Required only when CRM_PROVIDER=close
CLOSE_API_KEY=

# --- HubSpot CRM (optional) ---
# A HubSpot Private App access token (Settings → Integrations → Private Apps)
# with CRM scopes for contacts, deals, owners, and engagements. Auto-selected
# when set (or force it with CRM_PROVIDER=hubspot).
HUBSPOT_ACCESS_TOKEN=

# --- Pipedrive CRM (optional) ---
# A Pipedrive API token (Settings → Personal preferences → API). Auto-selected
# when set (or force it with CRM_PROVIDER=pipedrive). For a company domain base,
# set PIPEDRIVE_API_BASE=https://yourcompany.pipedrive.com/v1
PIPEDRIVE_API_TOKEN=
# PIPEDRIVE_API_BASE=

# --- Salesforce CRM (optional) ---
# An OAuth access token + your org's instance URL (from a connected app). Both
# required; auto-selected when set (or force it with CRM_PROVIDER=salesforce).
# Supply a current token, OR configure the refresh credentials below and the
# adapter will obtain/renew the access token (and instance URL) automatically.
SALESFORCE_ACCESS_TOKEN=
SALESFORCE_INSTANCE_URL=
# SALESFORCE_API_VERSION=60.0
# Optional OAuth refresh (recommended — SF access tokens are short-lived):
# SALESFORCE_REFRESH_TOKEN=
# SALESFORCE_CLIENT_ID=
# SALESFORCE_CLIENT_SECRET=
# SALESFORCE_TOKEN_URL=https://login.salesforce.com/services/oauth2/token

# --- Connect ANY CRM (optional, no per-vendor code) ---
# Point at a thin REST adapter that returns the universal shape (see
# src/lib/crm/providers/http.ts for the endpoints). Auto-selected when set.
CRM_HTTP_BASE_URL=
CRM_HTTP_TOKEN=

# --- Supabase (optional) ---
# Set these to back the CRM with a real multi-tenant database. When present, the
# app auto-selects the Supabase provider. Run migrations in supabase/migrations,
# then POST /api/admin/bootstrap (Bearer ADMIN_TOKEN) once to initialize an org.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Pin a single org (single-tenant). Otherwise the first org is used.
DEFAULT_ORG_ID=
# Protects the one-time bootstrap endpoint.
ADMIN_TOKEN=
# Optional: apply the schema over HTTPS via the Management API (sbp_… token).
SUPABASE_ACCESS_TOKEN=

# --- Auth (optional, multi-tenant) ---
# When true, app routes require a signed-in user and each user gets their own
# org (provisioned on first sign-in). Default off = public demo on shared org.
NEXT_PUBLIC_AUTH_REQUIRED=false
# Public site URL for SEO (robots/sitemap) and OAuth redirects.
NEXT_PUBLIC_SITE_URL=https://revenue-recall.app

# --- Outreach compliance (on by default; REQUIRED before real sending) ---
# Set OUTBOUND_COMPLIANCE=false only if you append your own footers. Email gets a
# CAN-SPAM footer (org name + postal address + unsubscribe); SMS gets "Reply STOP".
OUTBOUND_COMPLIANCE=true
OUTBOUND_ORG_NAME="Your Company"
# Physical postal address — legally required in commercial email (CAN-SPAM).
COMPLIANCE_ADDRESS=

# --- Autopilot scheduler (optional) ---
# Protects POST/GET /api/agent/cron. Vercel Cron is auto-trusted via its header;
# set this to also allow manual/secure triggering. See vercel.json for schedule.
CRON_SECRET=

# --- Communications (optional, provider-agnostic) ---
# Connect ANY provider with zero code: point these webhooks at your own gateway,
# automation tool, or provider. The app POSTs JSON {channel,to,subject,body,from}.
# This is the recommended, no-vendor-lock-in path.
EMAIL_WEBHOOK_URL=
SMS_WEBHOOK_URL=
VOICE_WEBHOOK_URL=
# Optional bearer token sent with every webhook POST (for your endpoint to verify).
COMMS_WEBHOOK_TOKEN=
# Bring your own number: used as the caller ID / "from" on outbound SMS + calls.
OUTBOUND_FROM_NUMBER=
# Buy/manage numbers via any provider: the app POSTs {action:"search"|"buy"|"list"}.
NUMBERS_WEBHOOK_URL=
NUMBERS_WEBHOOK_TOKEN=
# Built-in email adapters (alternative to a webhook): set ONE.
RESEND_API_KEY=
SENDGRID_API_KEY=
EMAIL_FROM=sales@example.com
# Optional built-in Twilio adapter for SMS + voice (all three required). Not needed
# if you use SMS_WEBHOOK_URL / VOICE_WEBHOOK_URL.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# TwiML URL that runs when an outbound Twilio call connects (optional).
CALL_TWIML_URL=

# --- Inbound replies (optional, two-way) ---
# Point Twilio's SMS webhook at /api/inbound/sms and your email provider's
# inbound-parse webhook at /api/inbound/email. The SMS webhook verifies Twilio's
# X-Twilio-Signature when TWILIO_AUTH_TOKEN (above) is set; otherwise it falls
# back to this shared token query param (?token=...):
INBOUND_TOKEN=
# When true, AI auto-sends replies in your voice; otherwise they queue to Approvals.
REPLY_AUTOPILOT=false

# --- Sequences (cadence runtime) ---
# When true, due sequence steps auto-send; otherwise they queue to Approvals.
SEQUENCE_AUTOPILOT=false
# Opt-in: draft due email/SMS steps via the Anthropic Batches API (~50% cheaper,
# async). Drafts arrive in Approvals minutes-to-an-hour later (collected by the
# cron) and are always queued for review, never auto-sent. Skips the humanness
# refine pass. Requires ANTHROPIC_API_KEY + (for cross-tick state) Supabase, and
# migration 0018_ai_batches. Leave false for synchronous, top-quality drafting.
SEQUENCE_BATCH=false

# --- Autonomous outbound guardrails (Autopilot "auto" mode) ---
# Make hands-off outbound safe and non-spammy. All optional.
# Don't re-touch the same deal within N days (default 3).
AGENT_COOLDOWN_DAYS=3
# After a soft "not interested / not now", wait N days then re-engage (default 30).
# A no today isn't a no forever — winnable deals come back around. 0 = re-engage freely.
AGENT_DECLINE_COOLDOWN_DAYS=30
# Max autonomous sends per run (0/unset = unlimited).
AGENT_DAILY_SEND_CAP=
# Hold sends during a UTC quiet-hours window (e.g. 22 / 8). Unset = always allowed.
AGENT_QUIET_START_UTC=
AGENT_QUIET_END_UTC=

# --- Billing (optional, Stripe) ---
# Self-serve checkout/portal stay inactive until these are set. Create the
# products/prices in Stripe, point a webhook at /api/billing/webhook, and paste:
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_SCALE=
# Enforce plan limits (off by default = unrestricted demo/trial). When "true", a
# plan without autopilot drafts to Approvals instead of auto-sending, etc.
BILLING_ENFORCE=false

# --- Neural voice (optional, in-house high-fidelity TTS) ---
# WebSocket URL of the self-hosted neural-TTS service (services/neural-voice,
# Kokoro engine by default). When set, every voice surface upgrades from the
# When set, every voice surface (briefs, call prep, role-play) upgrades from the
# browser engine to the neural voice automatically; unset = browser fallback.
NEXT_PUBLIC_NEURAL_VOICE_URL=
