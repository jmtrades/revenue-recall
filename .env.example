# --- Revenue Recall configuration ---
# Everything is optional: with no env vars the app runs on the built-in,
# in-memory CRM seeded with realistic demo data.

# Industry template (see src/lib/industries): real_estate | mortgage | insurance
# | saas | agency | auto | home_services | generic
NEXT_PUBLIC_INDUSTRY=real_estate

# Display name shown in the sidebar.
NEXT_PUBLIC_ORG_NAME="Your Company"

# Monthly revenue goal used for goal/forecast attainment.
NEXT_PUBLIC_MONTHLY_QUOTA=250000

# Active CRM provider: builtin | close | hubspot | salesforce | pipedrive
CRM_PROVIDER=builtin

# Persist the built-in (demo) CRM to disk so edits survive restarts on local /
# self-hosted node deploys. Off by default (pure in-memory, reseeds each boot).
# Production persistence is Supabase, not this. Optional dir override.
BUILTIN_PERSIST=false
# BUILTIN_PERSIST_DIR=.data

# --- AI execution layer (optional) ---
# With no key, AI drafting & briefs fall back to high-quality templates.
# Set this to generate tailored outreach and deal briefs with Claude.
ANTHROPIC_API_KEY=
# Optional: pin a model (defaults to claude-opus-4-8). Use claude-haiku-4-5 for
# faster/cheaper drafting at scale.
ANTHROPIC_MODEL=
# Optional thinking effort floor: low | medium | high | xhigh | max (Opus 4.6+).
# Higher = deeper reasoning but materially more tokens/cost — with a budget cap
# set, "xhigh"/"max" across all short drafts can exhaust it and force the
# template fallback. Leave unset for the per-call default; reserve xhigh/max for
# intelligence-heavy work.
ANTHROPIC_EFFORT=
# Optional margin guard: cap AI spend per org per month (USD). When hit, drafting
# transparently falls back to the free templates. 0 / unset = unlimited.
AI_MONTHLY_BUDGET_USD=
# Per-client burst guard on AI/voice endpoints (requests/min, default 30).
AI_RATE_LIMIT_PER_MIN=
# Per-client burst guard on state-mutating / send endpoints (requests/min, default 120).
WRITE_RATE_LIMIT_PER_MIN=
# Optional price overrides (USD per 1M tokens) if list prices change:
# AI_PRICE_OPUS_IN= / AI_PRICE_OPUS_OUT= / AI_PRICE_SONNET_IN= / ... / AI_PRICE_HAIKU_OUT=

# --- Close CRM (optional) ---
# Required only when CRM_PROVIDER=close
CLOSE_API_KEY=

# --- HubSpot CRM (optional) ---
# A HubSpot Private App access token (Settings → Integrations → Private Apps)
# with CRM scopes for contacts, deals, owners, and engagements. Auto-selected
# when set (or force it with CRM_PROVIDER=hubspot).
HUBSPOT_ACCESS_TOKEN=

# --- Pipedrive CRM (optional) ---
# A Pipedrive API token (Settings → Personal preferences → API). Auto-selected
# when set (or force it with CRM_PROVIDER=pipedrive). For a company domain base,
# set PIPEDRIVE_API_BASE=https://yourcompany.pipedrive.com/v1
PIPEDRIVE_API_TOKEN=
# PIPEDRIVE_API_BASE=

# --- Salesforce CRM (optional) ---
# An OAuth access token + your org's instance URL (from a connected app). Both
# required; auto-selected when set (or force it with CRM_PROVIDER=salesforce).
# Supply a current token, OR configure the refresh credentials below and the
# adapter will obtain/renew the access token (and instance URL) automatically.
SALESFORCE_ACCESS_TOKEN=
SALESFORCE_INSTANCE_URL=
# SALESFORCE_API_VERSION=60.0
# Optional OAuth refresh (recommended — SF access tokens are short-lived):
# SALESFORCE_REFRESH_TOKEN=
# SALESFORCE_CLIENT_ID=
# SALESFORCE_CLIENT_SECRET=
# SALESFORCE_TOKEN_URL=https://login.salesforce.com/services/oauth2/token

# --- Connect ANY CRM (optional, no per-vendor code) ---
# Point at a thin REST adapter that returns the universal shape (see
# src/lib/crm/providers/http.ts for the endpoints). Auto-selected when set.
CRM_HTTP_BASE_URL=
CRM_HTTP_TOKEN=

# --- Supabase (optional) ---
# Set these to back the CRM with a real multi-tenant database. When present, the
# app auto-selects the Supabase provider. Run migrations in supabase/migrations,
# then POST /api/admin/bootstrap (Bearer ADMIN_TOKEN) once to initialize an org.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Encrypts per-org connection secrets (social tokens, database URLs) at rest
# (AES-256-GCM). Required to use the self-serve Connect UI; min 16 chars. Keep
# it stable — rotating it invalidates stored secrets (orgs just reconnect).
ENCRYPTION_KEY=
# Pin a single org (single-tenant). Otherwise the first org is used.
DEFAULT_ORG_ID=
# Protects the one-time bootstrap endpoint.
ADMIN_TOKEN=
# Optional: apply the schema over HTTPS via the Management API (sbp_… token).
SUPABASE_ACCESS_TOKEN=

# --- Auth (multi-tenant) ---
# When Supabase is connected, sign-in is ALWAYS required and each user gets their
# own private org (provisioned on first sign-in) — this is not overridable, so a
# deploy with a database can't accidentally run open/shared. This flag only does
# anything WITHOUT a database: set it to true to gate the built-in demo store.
# Leave it UNSET in production.
# NEXT_PUBLIC_AUTH_REQUIRED=
# Public site URL for SEO (robots/sitemap) and OAuth redirects.
NEXT_PUBLIC_SITE_URL=https://revenue-recall.app

# --- Outreach compliance (on by default; REQUIRED before real sending) ---
# Set OUTBOUND_COMPLIANCE=false only if you append your own footers. Email gets a
# CAN-SPAM footer (org name + postal address + unsubscribe); SMS gets "Reply STOP".
OUTBOUND_COMPLIANCE=true
OUTBOUND_ORG_NAME="Your Company"
# Physical postal address — legally required in commercial email (CAN-SPAM).
# In production, outreach email REFUSES to send until an address exists (here or
# per-org in Settings → General). COMPLIANCE_REQUIRE_ADDRESS=false relaxes that
# only if your email gateway appends the address itself.
COMPLIANCE_ADDRESS=

# --- Autopilot scheduler (REQUIRED in production) ---
# Protects POST/GET /api/agent/cron. In production the cron REFUSES to run
# without this secret (the x-vercel-cron header alone is spoofable off-Vercel).
# Vercel Cron sends `Authorization: Bearer $CRON_SECRET` automatically once the
# env var exists. vercel.json runs it once daily (Vercel Hobby only allows daily
# crons). For hourly autopilot on the free tier, enable
# .github/workflows/autopilot.yml by adding repo secrets AGENT_CRON_URL +
# CRON_SECRET — or upgrade to Vercel Pro and set vercel.json back to "0 * * * *".
CRON_SECRET=

# --- Communications (optional, provider-agnostic) ---
# Connect ANY provider with zero code: point these webhooks at your own gateway,
# automation tool, or provider. The app POSTs JSON {channel,to,subject,body,from}.
# This is the recommended, no-vendor-lock-in path.
EMAIL_WEBHOOK_URL=
SMS_WEBHOOK_URL=
VOICE_WEBHOOK_URL=
# Optional bearer token sent with every webhook POST (for your endpoint to verify).
COMMS_WEBHOOK_TOKEN=
# Bring your own number: used as the caller ID / "from" on outbound SMS + calls.
OUTBOUND_FROM_NUMBER=
# Spoken at the very top of every outbound call when set (call-recording consent
# for two-party-consent states). Leave blank for single-party setups.
CALL_RECORDING_DISCLOSURE=
# AI-caller disclosure, spoken right after the recording disclosure. ON BY
# DEFAULT ("Quick heads-up: I'm <rep>'s AI assistant at <org>.") — state bot
# laws (e.g. California B&P 17941) and FCC AI-voice rules require an automated
# caller to identify itself, and the agent confirms honestly if asked. Set
# custom wording here, or "off" ONLY if you've verified your own jurisdictional
# footing.
CALL_AI_DISCLOSURE=
# Buy/manage numbers via any provider: the app POSTs {action:"search"|"buy"|"list"}.
NUMBERS_WEBHOOK_URL=
NUMBERS_WEBHOOK_TOKEN=
# Built-in email adapters (alternative to a webhook): set ONE.
RESEND_API_KEY=
SENDGRID_API_KEY=
EMAIL_FROM=sales@example.com
# Optional built-in Twilio adapter for SMS + voice (all three required). Not needed
# if you use SMS_WEBHOOK_URL / VOICE_WEBHOOK_URL.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# TwiML URL that runs when an outbound Twilio call connects (optional).
CALL_TWIML_URL=

# --- Inbound replies (optional, two-way) ---
# Point Twilio's SMS webhook at /api/inbound/sms and your email provider's
# inbound-parse webhook at /api/inbound/email. The SMS webhook verifies Twilio's
# X-Twilio-Signature when TWILIO_AUTH_TOKEN (above) is set; otherwise it falls
# back to this shared token query param (?token=...):
INBOUND_TOKEN=
# Preferred for inbound email: have your forwarding bridge HMAC-SHA256-sign the
# raw body with this secret and send it as the `x-rr-signature` header. When set,
# /api/inbound/email (and /api/inbound/bounce) require a valid signature
# (fail-closed) and ignore the token. Point your ESP's bounce + spam-complaint
# webhook at /api/inbound/bounce so hard bounces stop further email to that address.
INBOUND_SIGNING_SECRET=
# When true, AI auto-sends replies in your voice; otherwise they queue to Approvals.
REPLY_AUTOPILOT=false

# --- Sequences (cadence runtime) ---
# When true, due sequence steps auto-send; otherwise they queue to Approvals.
SEQUENCE_AUTOPILOT=false
# Opt-in: draft due email/SMS steps via the Anthropic Batches API (~50% cheaper,
# async). Drafts arrive in Approvals minutes-to-an-hour later (collected by the
# cron) and are always queued for review, never auto-sent. Skips the humanness
# refine pass. Requires ANTHROPIC_API_KEY + (for cross-tick state) Supabase, and
# migration 0018_ai_batches. Leave false for synchronous, top-quality drafting.
SEQUENCE_BATCH=false

# --- Autonomous outbound guardrails (Autopilot "auto" mode) ---
# Make hands-off outbound safe and non-spammy. All optional.
# Don't re-touch the same deal within N days (default 3).
AGENT_COOLDOWN_DAYS=3
# After a soft "not interested / not now", wait N days then re-engage (default 30).
# A no today isn't a no forever — winnable deals come back around. 0 = re-engage freely.
AGENT_DECLINE_COOLDOWN_DAYS=30
# Max autonomous sends per run (0/unset = unlimited).
AGENT_DAILY_SEND_CAP=
# Hold sends during a quiet-hours window (e.g. 20 / 8 = 8pm–8am). Unset = always
# allowed. The window is read in AGENT_TIMEZONE when set, else UTC — so when
# autopilot ticks hourly it stays off overnight in your recipients' local time.
AGENT_QUIET_START_UTC=
AGENT_QUIET_END_UTC=
# IANA timezone the quiet-hours window is interpreted in (e.g. America/New_York).
AGENT_TIMEZONE=

# --- Billing (optional, Stripe) ---
# Self-serve checkout/portal stay inactive until these are set. Create the
# products/prices in Stripe, point a webhook at /api/billing/webhook, and paste:
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Publishable key (pk_…, safe to expose). When set, checkout runs EMBEDDED on
# your own domain (buyers never leave the app); unset = hosted Stripe redirect.
# Read at RUNTIME — no rebuild needed, it works the moment you set it.
# (NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY is also accepted for back-compat.)
STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_TEAM=
STRIPE_PRICE_SCALE=
# Optional annual prices — when set, the landing/billing annual toggle checks out
# at these; if unset, annual falls back to the monthly price (no dead end).
STRIPE_PRICE_GROWTH_ANNUAL=
STRIPE_PRICE_TEAM_ANNUAL=
STRIPE_PRICE_SCALE_ANNUAL=
# Enforce plan limits. MARGIN-SAFE DEFAULT: leave this unset and limits enforce
# automatically the moment Stripe is connected (so you never serve unlimited live
# AI to free users). When enforcing, a free plan drafts to Approvals + uses free
# templates (no model spend); paid plans get their AI-message pool + top-ups.
# Set to "false" ONLY to deliberately run unlimited/open on top of billing.
# BILLING_ENFORCE=
# Optional usage top-ups: one-time "AI message" packs customers buy when they run
# low on their monthly pool (an AI message = each email, text, call script, or
# reply the AI writes). Create one-time prices in Stripe and paste the ids; each
# pack is purchasable only once its price is set. Amounts (1k/5k/25k) are defined
# in src/lib/billing/topups.ts.
STRIPE_PRICE_TOPUP_1K=
STRIPE_PRICE_TOPUP_5K=
STRIPE_PRICE_TOPUP_25K=

# --- Neural voice (optional, in-house high-fidelity TTS) ---
# WebSocket URL of the self-hosted neural-TTS service (services/neural-voice,
# Kokoro engine by default). When set, every voice surface (briefs, call prep,
# role-play) upgrades from the browser engine to the neural voice automatically;
# unset = browser fallback.
NEXT_PUBLIC_NEURAL_VOICE_URL=

# --- Hosted neural voice (optional fallback — most deploys need NO key) ---
# The DEFAULT studio voice is Kokoro running on-device in the browser: free,
# private, no vendor. These hosted keys are an optional fallback for devices
# that can't run it. Priority: in-house service > on-device Kokoro > ElevenLabs
# -> OpenAI > browser engine. House voices auto-map on every backend.
# Pin one explicitly (cartesia|elevenlabs|openai); else best-configured wins.
VOICE_TTS_PROVIDER=
# Cartesia Sonic — the current best latency/naturalness class for voice agents.
# Voices are account-scoped UUIDs: set a default id; optionally map house
# voices: CARTESIA_VOICE_MAP={"af_heart":"<uuid>","am_adam":"<uuid>"}
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=
CARTESIA_VOICE_MAP=
CARTESIA_MODEL=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=
OPENAI_API_KEY=
OPENAI_TTS_VOICE=
OPENAI_TTS_MODEL=

# --- Connect any database (optional, even if it's not a CRM) ---
# Point at any endpoint that returns lead rows as JSON — PostgREST (any Postgres
# table), Supabase REST, Airtable, NocoDB/Baserow, Sheets-as-JSON, or any array
# endpoint. We map the table's own column names onto the universal model.
DATA_SOURCE_URL=
DATA_SOURCE_TOKEN=
# Optional explicit column mapping (target -> source), else columns auto-detect:
# {"name":"full_name","email":"email_address","phone":"mobile","company":"account","value":"deal_size","stage":"status","id":"uuid"}
DATA_SOURCE_MAPPING=
# How many lead rows to create in parallel on CSV/bulk import (default 8).
IMPORT_CONCURRENCY=8

# --- Omnichannel social (optional) ---
# Each platform is inert until its keys are set; point its webhook at
# /api/social/<platform>. Inbound DMs flow into the unified inbox; replies go
# back out on the same channel.
# WhatsApp Business (Meta Cloud API):
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=
# Instagram DMs (Meta):
IG_TOKEN=
IG_APP_SECRET=
IG_VERIFY_TOKEN=
# Facebook Messenger (Meta):
MESSENGER_PAGE_TOKEN=
MESSENGER_APP_SECRET=
MESSENGER_VERIFY_TOKEN=
# Telegram Bot API:
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
# X (Twitter) DMs — needs elevated API access; X_API_SECRET enables inbound + CRC:
X_BEARER_TOKEN=
X_API_SECRET=
# LinkedIn (partner-gated; send-only until inbound polling is configured):
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_API_VERSION=

# --- Social OAuth "Connect with…" (optional) ---
# Register a developer app per platform and set its client id/secret here. When
# set, Settings shows a "Connect with <platform>" button that runs the OAuth
# login (no token pasting) and stores the resulting token per org, encrypted.
# When unset, the platform still works via the paste-keys form above.
# Meta (Instagram + Messenger share one app):
META_APP_ID=
META_APP_SECRET=
# X (Twitter) OAuth2 + PKCE:
X_CLIENT_ID=
X_CLIENT_SECRET=
# LinkedIn OAuth2:
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# --- Public contact mailboxes (optional) ---
# Shown on the marketing site (footer, legal pages, security.txt, pricing).
# Each defaults to the matching mailbox on recall-touch.com when unset.
NEXT_PUBLIC_SUPPORT_EMAIL=
NEXT_PUBLIC_LEGAL_EMAIL=
NEXT_PUBLIC_SECURITY_EMAIL=
NEXT_PUBLIC_SALES_EMAIL=
