# --- Revenue Recall configuration ---
# Everything is optional: with no env vars the app runs on the built-in,
# in-memory CRM seeded with realistic demo data.

# Industry template (see src/lib/industries): real_estate | mortgage | insurance
# | saas | agency | auto | home_services | generic
NEXT_PUBLIC_INDUSTRY=real_estate

# Display name shown in the sidebar.
NEXT_PUBLIC_ORG_NAME="Your Company"

# Monthly revenue goal used for goal/forecast attainment.
NEXT_PUBLIC_MONTHLY_QUOTA=250000

# Active CRM provider: builtin | close | hubspot | salesforce | pipedrive
CRM_PROVIDER=builtin

# Persist the built-in (demo) CRM to disk so edits survive restarts on local /
# self-hosted node deploys. Off by default (pure in-memory, reseeds each boot).
# Production persistence is Supabase, not this. Optional dir override.
BUILTIN_PERSIST=false
# BUILTIN_PERSIST_DIR=.data

# --- AI execution layer (optional) ---
# With no key, AI drafting & briefs fall back to high-quality templates.
# Set this to generate tailored outreach and deal briefs with Claude.
ANTHROPIC_API_KEY=
# Optional: pin a model (defaults to claude-opus-4-7). Use claude-haiku-4-5 for
# faster/cheaper drafting at scale.
ANTHROPIC_MODEL=

# --- Close CRM (optional) ---
# Required only when CRM_PROVIDER=close
CLOSE_API_KEY=

# --- Supabase (optional) ---
# Set these to back the CRM with a real multi-tenant database. When present, the
# app auto-selects the Supabase provider. Run migrations in supabase/migrations,
# then POST /api/admin/bootstrap (Bearer ADMIN_TOKEN) once to initialize an org.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Pin a single org (single-tenant). Otherwise the first org is used.
DEFAULT_ORG_ID=
# Protects the one-time bootstrap endpoint.
ADMIN_TOKEN=
# Optional: apply the schema over HTTPS via the Management API (sbp_… token).
SUPABASE_ACCESS_TOKEN=

# --- Auth (optional, multi-tenant) ---
# When true, app routes require a signed-in user and each user gets their own
# org (provisioned on first sign-in). Default off = public demo on shared org.
NEXT_PUBLIC_AUTH_REQUIRED=false
# Public site URL for SEO (robots/sitemap) and OAuth redirects.
NEXT_PUBLIC_SITE_URL=https://revenue-recall.app

# --- Autopilot scheduler (optional) ---
# Protects POST/GET /api/agent/cron. Vercel Cron is auto-trusted via its header;
# set this to also allow manual/secure triggering. See vercel.json for schedule.
CRON_SECRET=

# --- Communications (optional) ---
# Email: set ONE of these (else messages are logged to the timeline).
RESEND_API_KEY=
SENDGRID_API_KEY=
EMAIL_FROM=sales@example.com
# SMS + Voice via Twilio (all three required to go live).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# TwiML URL that runs when an outbound call connects (optional).
CALL_TWIML_URL=

# --- Inbound replies (optional, two-way) ---
# Point Twilio's SMS webhook at /api/inbound/sms and your email provider's
# inbound-parse webhook at /api/inbound/email. The SMS webhook verifies Twilio's
# X-Twilio-Signature when TWILIO_AUTH_TOKEN (above) is set; otherwise it falls
# back to this shared token query param (?token=...):
INBOUND_TOKEN=
# When true, AI auto-sends replies in your voice; otherwise they queue to Approvals.
REPLY_AUTOPILOT=false

# --- Sequences (cadence runtime) ---
# When true, due sequence steps auto-send; otherwise they queue to Approvals.
SEQUENCE_AUTOPILOT=false

# --- Billing (optional, Stripe) ---
# Self-serve checkout/portal stay inactive until these are set. Create the
# products/prices in Stripe, point a webhook at /api/billing/webhook, and paste:
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_SCALE=
