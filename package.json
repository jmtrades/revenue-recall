{
  "name": "revenue-recall",
  "version": "0.1.0",
  "private": true,
  "description": "Revenue Recall — a universal sales OS that works with any CRM (or none) and adapts to any industry.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "smoke": "node scripts/smoke.mjs",
    "smoke:crm": "CRM_LIVE_SMOKE=1 vitest run tests/live/crm.live.test.ts",
    "smoke:ai": "AI_LIVE_SMOKE=1 vitest run tests/live/ai.live.test.ts",
    "scan:secrets": "bash scripts/scan-secrets.sh",
    "db:migrate": "bash scripts/db-migrate.sh",
    "db:bootstrap": "bash scripts/db-bootstrap.sh",
    "predev": "node scripts/copy-kokoro.mjs",
    "prebuild": "node scripts/copy-kokoro.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.97.1",
    "@elevenlabs/elevenlabs-js": "^2.53.0",
    "@elevenlabs/react": "^1.6.7",
    "@stripe/stripe-js": "^9.7.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.45.4",
    "@types/three": "^0.184.1",
    "kokoro-js": "^1.2.1",
    "motion": "^12.40.0",
    "next": "14.2.35",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "three": "^0.184.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.5.4",
    "vitest": "^2.1.9"
  }
}
